# OPTIONAL: Only needed if using Docker for drizzle-kit studio or development database access.
# The app uses an embedded database (PGlite) — no external database is required.

# Database password for Docker Compose PostgreSQL
DB_PASSWORD=localdev

# Full connection string (optional — only used by drizzle-kit CLI)
# DATABASE_URL=postgresql://dashboard:localdev@localhost:5432/living_dashboard

# ─────────────────────────────────────────────────────────────────────────────
# Windows Code Signing (optional — only needed for Windows builds)
# ─────────────────────────────────────────────────────────────────────────────
# CERT_PASSWORD=your-pfx-certificate-password

# ─────────────────────────────────────────────────────────────────────────────
# macOS Code Signing & Notarization (optional — only needed for macOS builds)
# Requires an Apple Developer account ($99/year).
# ─────────────────────────────────────────────────────────────────────────────
# APPLE_IDENTITY=Developer ID Application: Your Name (TEAMID)
# APPLE_ID=your@email.com
# APPLE_PASSWORD=app-specific-password
# APPLE_TEAM_ID=YOURTEAMID
