# Exclude dev/internal files from GitHub source archives (zip/tar.gz on Releases page).
# These files are tracked in git but should NOT appear in customer-facing downloads.

# Dev docs
CONTRIBUTING.md         export-ignore
docs/                   export-ignore

# Dev artifacts
prettier_err.txt        export-ignore
tsc_out.txt             export-ignore
tsc_out2.txt            export-ignore
release-commands.txt    export-ignore

# Build/dev scripts and installer
scripts/                export-ignore
installer/              export-ignore
docker-compose.yml      export-ignore

# Test files
src/**/*.test.ts        export-ignore
src/**/*.test.tsx       export-ignore
src/**/*.spec.ts        export-ignore
vitest.config.*         export-ignore
