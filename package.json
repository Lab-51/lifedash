{
  "name": "lifedash",
  "version": "2.2.15",
  "description": "AI-powered Electron desktop dashboard for professionals",
  "author": "Daniel Rieger",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lab-51/lifedash.git"
  },
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:installer": "node scripts/build-installer.js",
    "make:archive": "node scripts/build-zip.js",
    "make:dist": "electron-forge package && npm run make:installer && npm run make:archive",
    "publish": "npm run make:dist && node scripts/upload-release.js",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint src/",
    "lint:prettier": "prettier --check src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test --config playwright.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "make:icons": "node scripts/make-icons.js",
    "verify:package": "node scripts/verify-package.js",
    "demo:record": "node scripts/record-demo.mjs",
    "demo:overlay": "bash scripts/demo-overlay.sh",
    "demo:gif": "bash scripts/demo-overlay.sh --gif",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.43",
    "@ai-sdk/openai": "^3.0.28",
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.7",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@electric-sql/pglite": "^0.3.15",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@fontsource/share-tech-mono": "^5.2.7",
    "@fugood/whisper.node": "^1.0.16",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@mozilla/readability": "^0.6.0",
    "@sentry/electron": "^7.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@types/dompurify": "^3.0.5",
    "@types/react-window": "^1.8.8",
    "ai": "^6.0.84",
    "dompurify": "^3.3.3",
    "drizzle-orm": "^0.45.1",
    "electron-audio-loopback": "^1.0.6",
    "electron-window-state": "^5.0.3",
    "focus-trap-react": "^12.0.0",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.563.0",
    "node-machine-id": "^1.1.12",
    "ollama-ai-provider": "^1.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "react-window": "^2.2.7",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "tslib": "^2.8.1",
    "undici": "^7.22.0",
    "update-electron-app": "^3.1.2",
    "wavefile": "^11.0.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-wix": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/notarize": "^3.1.1",
    "@electron/osx-sign": "^2.3.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.4.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "javascript-obfuscator": "^5.3.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ],
    "src/**/*.{ts,tsx,css,json,md}": [
      "prettier --check"
    ]
  }
}
